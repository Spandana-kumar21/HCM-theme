{% doc %}
  @prompt
    create job listing, one below the other with Learn more button in line with it, thi is perfect, remove the border around each job, add title of the section at the top, add possibility to change colour font and colout weight, and add posisibility to post up to 15 jobs, for this section, leave 50px margin from the left and from the right side
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-job-listing-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding-left: 50px;
    padding-right: 50px;
  }

  .ai-job-listing__header-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.title_margin_bottom }}px;
  }

  .ai-job-listing__section-title-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.section_title_font_size }}px;
    font-weight: {{ block.settings.section_title_font_weight }};
    color: {{ block.settings.section_title_color }};
    text-align: {{ block.settings.section_title_alignment }};
  }

  .ai-job-listing__container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.spacing_between_jobs }}px;
  }

  .ai-job-listing__item-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
    padding: {{ block.settings.job_padding }}px;
    background-color: {{ block.settings.job_background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    transition: all 0.3s ease;
  }

  .ai-job-listing__item-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.job_hover_background_color }};
  }

  .ai-job-listing__content-{{ ai_gen_id }} {
    flex: 1;
    min-width: 0;
  }

  .ai-job-listing__title-{{ ai_gen_id }} {
    margin: 0 0 8px 0;
    font-size: {{ block.settings.title_font_size }}px;
    font-weight: {{ block.settings.title_font_weight }};
    color: {{ block.settings.title_color }};
  }

  .ai-job-listing__details-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: 8px;
  }

  .ai-job-listing__detail-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: {{ block.settings.detail_font_size }}px;
    font-weight: {{ block.settings.detail_font_weight }};
    color: {{ block.settings.detail_color }};
  }

  .ai-job-listing__detail-icon-{{ ai_gen_id }} {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  .ai-job-listing__description-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.description_font_size }}px;
    font-weight: {{ block.settings.description_font_weight }};
    color: {{ block.settings.description_color }};
    line-height: 1.5;
  }

  .ai-job-listing__button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px 24px;
    background-color: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    text-decoration: none;
    white-space: nowrap;
    transition: all 0.3s ease;
  }

  .ai-job-listing__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-job-listing-{{ ai_gen_id }} {
      padding-left: 20px;
      padding-right: 20px;
    }

    .ai-job-listing__item-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: flex-start;
    }

    .ai-job-listing__button-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<div class="ai-job-listing-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.section_title != blank %}
    <div class="ai-job-listing__header-{{ ai_gen_id }}">
      <h2 class="ai-job-listing__section-title-{{ ai_gen_id }}">{{ block.settings.section_title }}</h2>
    </div>
  {% endif %}

  <div class="ai-job-listing__container-{{ ai_gen_id }}">
    {% for i in (1..15) %}
      {% liquid
        assign job_enabled_key = 'job_' | append: i | append: '_enabled'
        assign job_title_key = 'job_' | append: i | append: '_title'
        assign job_location_key = 'job_' | append: i | append: '_location'
        assign job_type_key = 'job_' | append: i | append: '_type'
        assign job_description_key = 'job_' | append: i | append: '_description'
        assign job_link_key = 'job_' | append: i | append: '_link'

        assign job_enabled = block.settings[job_enabled_key]
        assign job_title = block.settings[job_title_key]
        assign job_location = block.settings[job_location_key]
        assign job_type = block.settings[job_type_key]
        assign job_description = block.settings[job_description_key]
        assign job_link = block.settings[job_link_key]
      %}

      {% if job_enabled %}
        <div class="ai-job-listing__item-{{ ai_gen_id }}">
          <div class="ai-job-listing__content-{{ ai_gen_id }}">
            {% if job_title != blank %}
              <h3 class="ai-job-listing__title-{{ ai_gen_id }}">{{ job_title }}</h3>
            {% endif %}

            <div class="ai-job-listing__details-{{ ai_gen_id }}">
              {% if job_location != blank %}
                <div class="ai-job-listing__detail-{{ ai_gen_id }}">
                  <svg class="ai-job-listing__detail-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                    <circle cx="12" cy="10" r="3"></circle>
                  </svg>
                  <span>{{ job_location }}</span>
                </div>
              {% endif %}

              {% if job_type != blank %}
                <div class="ai-job-listing__detail-{{ ai_gen_id }}">
                  <svg class="ai-job-listing__detail-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect>
                    <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path>
                  </svg>
                  <span>{{ job_type }}</span>
                </div>
              {% endif %}
            </div>

            {% if job_description != blank %}
              <p class="ai-job-listing__description-{{ ai_gen_id }}">{{ job_description }}</p>
            {% endif %}
          </div>

          <a href="{{ job_link }}" class="ai-job-listing__button-{{ ai_gen_id }}">
            {{ block.settings.button_text }}
          </a>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</div>

