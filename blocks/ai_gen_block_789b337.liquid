{% doc %}
  @prompt
    create job listing, one below the other with Learn more button in line with it, remove the border around each job, add title of the section at the top, add possibility to change colour font and colour weight, and add possibility to post up to 15 jobs, for this section, align right and left padding/margin with other sections on this page, make full time position and location as icons with text
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-job-listings-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding-left: 26px;
    padding-right: 26px;
    max-width: 100%;
  }

  .ai-job-listings-container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
  }

  .ai-job-listings-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.title_font.family }}, {{ block.settings.title_font.fallback_families }};
    font-weight: {{ block.settings.title_font.weight }};
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 40px 0;
    text-align: {{ block.settings.title_alignment }};
  }

  .ai-job-listings-list-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .ai-job-item-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
    padding: 24px 0;
  }

  .ai-job-item-{{ ai_gen_id }}:not(:last-child) {
    border-bottom: 1px solid {{ block.settings.divider_color }};
  }

  .ai-job-content-{{ ai_gen_id }} {
    flex-grow: 1;
  }

  .ai-job-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.job_title_font.family }}, {{ block.settings.job_title_font.fallback_families }};
    font-weight: {{ block.settings.job_title_font.weight }};
    font-size: {{ block.settings.job_title_size }}px;
    color: {{ block.settings.job_title_color }};
    margin: 0 0 12px 0;
  }

  .ai-job-meta-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 8px;
    flex-wrap: wrap;
  }

  .ai-job-meta-item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: {{ block.settings.meta_font_size }}px;
    color: {{ block.settings.meta_color }};
  }

  .ai-job-meta-item-{{ ai_gen_id }} svg {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    flex-shrink: 0;
    color: {{ block.settings.icon_color }};
  }

  .ai-job-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.job_description_size }}px;
    color: {{ block.settings.job_description_color }};
    margin: 0;
    line-height: 1.5;
  }

  .ai-job-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px 24px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s ease;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .ai-job-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-job-listings-{{ ai_gen_id }} {
      padding-left: 20px;
      padding-right: 20px;
    }

    .ai-job-item-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
    }

    .ai-job-button-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-job-listings-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.7 }}px;
      margin-bottom: 30px;
    }

    .ai-job-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.job_title_size | times: 0.85 }}px;
    }

    .ai-job-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.job_description_size | times: 0.9 }}px;
    }

    .ai-job-meta-{{ ai_gen_id }} {
      gap: 16px;
    }
  }
{% endstyle %}

<div class="ai-job-listings-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-job-listings-container-{{ ai_gen_id }}">
    {% if block.settings.section_title != blank %}
      <h2 class="ai-job-listings-title-{{ ai_gen_id }}">{{ block.settings.section_title }}</h2>
    {% endif %}

    <div class="ai-job-listings-list-{{ ai_gen_id }}">
      {% for i in (1..15) %}
        {% liquid
          assign job_title_key = 'job_' | append: i | append: '_title'
          assign job_type_key = 'job_' | append: i | append: '_type'
          assign job_location_key = 'job_' | append: i | append: '_location'
          assign job_description_key = 'job_' | append: i | append: '_description'
          assign job_link_key = 'job_' | append: i | append: '_link'
          assign job_enabled_key = 'job_' | append: i | append: '_enabled'

          assign job_title = block.settings[job_title_key]
          assign job_type = block.settings[job_type_key]
          assign job_location = block.settings[job_location_key]
          assign job_description = block.settings[job_description_key]
          assign job_link = block.settings[job_link_key]
          assign job_enabled = block.settings[job_enabled_key]
        %}

        {% if job_enabled and job_title != blank %}
          <div class="ai-job-item-{{ ai_gen_id }}">
            <div class="ai-job-content-{{ ai_gen_id }}">
              <h3 class="ai-job-title-{{ ai_gen_id }}">{{ job_title }}</h3>
              
              {% if job_type != blank or job_location != blank %}
                <div class="ai-job-meta-{{ ai_gen_id }}">
                  {% if job_type != blank %}
                    <div class="ai-job-meta-item-{{ ai_gen_id }}">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect>
                        <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path>
                      </svg>
                      <span>{{ job_type }}</span>
                    </div>
                  {% endif %}
                  
                  {% if job_location != blank %}
                    <div class="ai-job-meta-item-{{ ai_gen_id }}">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                        <circle cx="12" cy="10" r="3"></circle>
                      </svg>
                      <span>{{ job_location }}</span>
                    </div>
                  {% endif %}
                </div>
              {% endif %}

              {% if job_description != blank %}
                <p class="ai-job-description-{{ ai_gen_id }}">{{ job_description }}</p>
              {% endif %}
            </div>
            <a href="{{ job_link }}" class="ai-job-button-{{ ai_gen_id }}">
              {{ block.settings.button_text }}
            </a>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

