      ],
      "settings": {
        "custom_liquid": "<section id=\"download-ebook\">\n<div class=\"featured-block-container-e\">\n        <div class=\"featured-block-image-e\">\n                <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0801\/1307\/4523\/files\/Figure_about_us_1_jpg_5d363a5a-08d0-4018-bd05-ec29ea3c0d89.png?v=1725885883\">\n        <\/div>\n        <div class=\"featured-block-content-e\">\n                <div class=\"featured-block-content-container-e card__text spacing--large remove-empty-space\">                        \n                        <h2 class=\"h3 rte rich-text__title\">\n                               Master Operational <\/br>Challenges \n                        <\/h2>\n                        <div class=\"rte text-size--regular\">\n                               <p>Our eBook, <strong>‘Farewell to Complexity, Hello to Streamlined Success’<\/strong> guides nursing home leaders through practical strategies to overcome financial and operational challenges, empowering them to achieve greater efficiency and success.<\/p>\n\t\t\t\t\t\t\t\t\t\n\n\n\n\n\n\n\n                        <\/div>\n                        <div class=\"increased-spacing\">\n                                <a id=\"downlaod-btn-e\" class=\"uil-download-alt button button--large button--outline\" target=\"_blank\" href=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0801\/1307\/4523\/files\/Res_Care_Ebook_2.pdf?v=1726153281\">Download PDF Brochure<\/a>\n                        <\/div>\n                <\/div>\n        <\/div>\n<\/div>\n<\/section>",
        "full_width": true,
        "remove_margin": false
      }
    },
