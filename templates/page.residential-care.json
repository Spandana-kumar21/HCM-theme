      ],
      "settings": {
        "custom_liquid": "<div class=\"featured-block-container-d\">\n        <div class=\"featured-block-image-d\">\n                <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0801\/1307\/4523\/files\/carer-1.png?v=1725284416\">\n        <\/div>\n        <div class=\"featured-block-content-d\">\n                <div class=\"featured-block-content-container-c card__text spacing--large remove-empty-space\">                        \n                        <h2 class=\"h3 rte rich-text__title\">\n                               Efficiency and Transparency <\/br> in One Platform.\n                        <\/h2>\n                        <div class=\"rte text-size--regular\">\n                                <strong>Homecare View provides full visibility into your purchases, helping you manage and reduce costs across all facilities.<\/strong>\n\t\t\t\t\t\t\t\t\t<p style=\"margin-top:10px;\" >From financial transparency to seamless product rollout, Homecare View Care allows you to streamline operations and enhance the quality of care provided.<\/p>\n\n\n\n\n\n\n\n                        <\/div>\n                        <div class=\"increased-spacing\">\n                                <a class=\"feat-outline-green-c button button--large button--outline\" href=\"#register\">Register your interest<\/a>\n                        <\/div>\n                <\/div>\n        <\/div>\n<\/div>",
        "full_width": true,
        "remove_margin": false
      }
