        "custom_liquid": "<div class=\"video-container\">\n<img class=\"tofarvel-video-poster show-on-mobile\" src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0801\/1307\/4523\/files\/trusted-by.png?v=1725291183\">\n\t<img class=\"tofarvel-video-poster show-on-desktop\" src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0801\/1307\/4523\/files\/Video.png?v=1726056088\">\n\t\n       \n        <div class=\"no-overlay\">\n                <div class=\"rte text-size--regular\">\n                        <p>\n                                Hear from Our Partners\n                        <\/p>\n                <\/div>\n                <h2 class=\"h2 rte rich-text__title\">\n                      Trusted by Ireland’s<\/br> Leading Nursing Homes\n                <\/h2>\n                <div class=\"buttons-wrapper\">\n                       \n                        <div class=\"increased-spacing\">\n                                <a class=\"mobx button button--large button--outline\" href=\"https:\/\/cdn.shopify.com\/videos\/c\/o\/v\/34c174afcf1b4ab18a1a3cdbbe19f928.mp4\">Watch Video<\/a>\n                        <\/div>\n                <\/div>\n        <\/div>\n<\/div>\n<div class=\"video-description\">\n<p>Homecare Medical is proud to partner with some of Ireland’s most respected nursing home groups. <\/p>\n<\/div>",
