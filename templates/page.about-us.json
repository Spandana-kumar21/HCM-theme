        "title_JhTBfe": {
          "type": "title",
          "settings": {
            "title": "Why Homecare Medical?",
            "title_size": "h3",
            "seo_h_tag": "h2"
          }
        },
        "text_Gtg8Gh": {
          "type": "text",
          "settings": {
            "text": "<p>We have been providing products to help you care for yourself or a loved one for over 35 years. We know the market, and ensure that we are constantly innovating and delivering best-in-class products. <br\/><\/p>",
            "text_size": "regular"
          }
        }
      },
