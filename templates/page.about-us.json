    "3e119ea9-1b07-4a11-b992-c7f03c9cee14": {
      "type": "rich-text",
      "blocks": {
        "template--20685976404315__3e119ea9-1b07-4a11-b992-c7f03c9cee14-title-1": {
          "type": "title",
          "settings": {
            "title": "Valued Care Partners",
            "title_size": "h3",
            "seo_h_tag": "h2"
          }
        },
        "template--20685976404315__3e119ea9-1b07-4a11-b992-c7f03c9cee14-text-1": {
          "type": "text",
          "settings": {
            "text": "<p>We are reliable care partners, delivering best-in-class products and innovative services.<\/p>",
            "text_size": "large"
          }
        },
        "text_HKrRtY": {
          "type": "text",
          "settings": {
            "text": "<p>Our products and services are in every care setting across the island of Ireland, from private homes, residential care, and hospitals to primary care centres and schools. <\/p><p>In these settings, our products and services are making a real difference. They’re freeing up carers to focus on the important work of helping those in care.<\/p>",
            "text_size": "regular"
          }
        }
      },
      "block_order": [
        "template--20685976404315__3e119ea9-1b07-4a11-b992-c7f03c9cee14-title-1",
