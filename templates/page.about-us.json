      ],
      "settings": {
        "custom_liquid": "<div id=\"page-banner-purple\" class=\"banner-purple image-right\">\n\t<div class=\"banner-inner\">\n        <div class=\"banner-content\">\n<span class=\"text-size--large subheading-bold-white\">Our Commitment to Care<\/span>\n                <h2 class=\"h2 rte rich-text__title\">We are at Your Service<\/h2>\n                <div class=\"rte text-size--large\">\n                        <p>Homecare Medical is much more than a retail store, we are your partner in care. From product recommendations and in-home consultations, to advice and know-how, our expert care staff offers a variety of services to help you care for yourself or your loved ones. \n<\/p>\n                       \n                <\/div>\n\t\t\t<div class=\"rte text-size--regular\">\n                \n                <\/div>\n\n        <\/div>\n        <div class=\"banner-image\"><img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0801\/1307\/4523\/files\/Group_3229.jpg?v=1715346308\"><\/div>\n\t<\/div>\n<\/div>",
        "full_width": true,
        "remove_margin": false
      }
    },
