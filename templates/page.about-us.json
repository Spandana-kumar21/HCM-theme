    "rich_text_PaTfNF": {
      "type": "rich-text",
      "blocks": {
        "title_6VHzj4": {
          "type": "title",
          "settings": {
            "title": "A Keen Focus on Sustainability",
            "title_size": "h3",
            "seo_h_tag": "h2"
          }
        },
        "text_b9GLYX": {
          "type": "text",
          "settings": {
            "text": "<p>Community, in all its forms, is part of our ethos. We are aiming to create a sustainable Homecare Medical community.<\/p>",
            "text_size": "large"
          }
        },
        "text_Ki4aP9": {
          "type": "text",
          "settings": {
            "text": "<p>We are committed to working with local Irish communities and charities to provide support to people who need care, in a sustainable and equitable way. <\/p>",
            "text_size": "regular"
          }
        }
      },
      "block_order": [
