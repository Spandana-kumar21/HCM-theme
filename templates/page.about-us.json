        "title_93FEYR": {
          "type": "title",
          "settings": {
            "title": "The Homecare Medical Story",
            "title_size": "h2",
            "seo_h_tag": "h2"
          }
        },
        "template--20685976404315__15923bcc-43ce-4bf1-9097-94adeafd2c24-text-1": {
          "type": "text",
          "settings": {
            "text": "<p>For over 35 years we’ve been providing products and services that support carers, enable the cared-for, and empower self-carers to remain in the comfort and familiarity of their own home for as long as possible.<\/p>",
            "text_size": "large"
          }
        }
      },
      "block_order": [
        "title_93FEYR",
        "template--20685976404315__15923bcc-43ce-4bf1-9097-94adeafd2c24-text-1"
