        "template--20685976404315__246e138e-af82-422b-b44a-b8ade034b0b8-text-1": {
          "type": "text",
          "settings": {
            "text": "<p>We are a family-owned business from the West of Ireland. Our family values of care and empathy filter through our business, and are as important to us as the skills, abilities, and work ethic of our 120-strong team. <\/p>",
            "text_size": "regular"
          }
        }
      },
      "block_order": [
