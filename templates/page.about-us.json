    "c825dccd-0bec-41c1-aa03-63cc063e2deb": {
      "type": "custom-liquid",
      "custom_css": [
        ".rte p {color: #350078;}"
      ],
      "settings": {
        "custom_liquid": "<div id=\"page-banner-green\" class=\"banner-green image-right\">\n\t<div class=\"banner-inner\">\n        <div class=\"banner-content\">\n                <h2 class=\"h3 rte rich-text__title\">Home is Where the <\/br>Heart is <\/h2>\n                <div class=\"rte text-size--large\">\n                        <p>Wherever you call home, we want to make sure you and your loved ones can stay there as long as possible.<\/p>\n                <\/div>\n\t\t\t<div class=\"rte text-size--regular\">\n                        <p>With our comfort and safety solutions, we can make your home a sanctuary, where you can take care of yourself or your loved one. <\/p>\n                <\/div>\n        <\/div>\n        <div class=\"banner-image\"><img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0801\/1307\/4523\/files\/hcm_care_at_home_01a.png?v=1716477050\"><\/div>\n\t<\/div>\n<\/div>",
        "full_width": true,
        "remove_margin": false
      }
    },
    "c0192f25-eec4-44fd-9b1b-3956e04a7083": {
      "type": "rich-text",
      "blocks": {
        "template--20685976404315__c0192f25-eec4-44fd-9b1b-3956e04a7083-text-1": {
          "type": "text",
          "settings": {
            "text": "<p>Products designed to provide care<\/p>",
            "text_size": "large"
          }
        },
        "text_ifqeMp": {
          "type": "text",
          "settings": {
            "text": "<p>Our best-in-class products have been developed to aid caregiving, and enhance your health and wellbeing. From mobility, incontinence, and pain management, to home comfort, safety, and supports, our products cover all areas of caregiving. <\/p>",
            "text_size": "regular"
          }
        },
        "text_mzYVqm": {
          "type": "text",
          "settings": {
            "text": "<p>Services tailored to meet your needs<br\/><\/p>",
            "text_size": "large"
          }
        },
        "text_zBKQrj": {
          "type": "text",
          "settings": {
            "text": "<p>Our range of specialised services can be modified to suit your home and your needs, whether that’s customised seating or a home modification we are happy to advise and help. <\/p>",
            "text_size": "regular"
          }
        },
        "text_jbWWAH": {
          "type": "text",
          "settings": {
            "text": "<p>Caring staff offer sound advice<\/p>",
            "text_size": "large"
          }
        },
        "text_NF3Ytc": {
          "type": "text",
          "settings": {
            "text": "<p>Our helpful in-store staff have the knowledge and expertise to listen and respond to your specific needs. We know that everyone is different; that’s why our expert team have been trained to offer advice customized for every situation. <\/p>",
            "text_size": "regular"
          }
        }
      },
      "block_order": [
