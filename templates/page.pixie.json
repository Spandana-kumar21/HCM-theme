der-item\">\n\n        <div class=\"card__icon card__icon--is-img card__icon-size--large lazyloaded\" id=\"element-image_JqbY3W\"><img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0801\/1307\/4523\/files\/brain_1.svg?v=1716999215\" alt=\"\" srcset=\"\n                https:\/\/cdn.shopify.com\/s\/files\/1\/0801\/1307\/4523\/files\/brain_1.svg?v=1716999215\n                 \n                 \n                 \n              \" loading=\"lazy\" sizes=\"(max-width: 474px) 60px, (max-width: 1023px) 80px, 110px\" width=\"64\" height=\"64\" onload=\"this.parentNode.classList.add('lazyloaded')\"><\/div>\n\n        <div class=\"gutter--regular spacing--small remove-empty-space\"><div style=\"color:var(--color-text-main)\">\n              <h3 class=\"h5\" style=\"margin-bottom:0;display:block\"><span class=\"text-animation--underline\">Cognitive & Physical<\/span><\/h3>\n            <\/div><div class=\"text-size--small text-color--opacity\" style=\"color:var(--color-text-main)\">Stimulates the cared for both cognitively and physically.<\/div><\/div>\n      <\/div><style data-shopify=\"\">\n          #element-image_JqbY3W {\n            background-color: #f8f1e4;\n          }\n        <\/style>\n<div class=\"item item3 element--no-border text-align--center element--no-radius js-slider-item\">\n\n        <div class=\"card__icon card__icon--is-img card__icon-size--large lazyloaded\" id=\"element-image_NF8kdK\"><img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0801\/1307\/4523\/files\/people_2.svg?v=1716999325\" alt=\"\" srcset=\"\n                https:\/\/cdn.shopify.com\/s\/files\/1\/0801\/1307\/4523\/files\/people_2.svg?v=1716999325\n                 \n                 \n                 \n              \" loading=\"lazy\" sizes=\"(max-width: 474px) 60px, (max-width: 1023px) 80px, 110px\" width=\"64\" height=\"64\" onload=\"this.parentNode.classList.add('lazyloaded')\"><\/div>\n\n        <div class=\"gutter--regular spacing--small remove-empty-space\"><div style=\"color:var(--color-text-main)\">\n              <h3 class=\"h5\" style=\"margin-bottom:0;display:block\"><span class=\"text-animation--underline\">Social<\/span><\/h3>\n            <\/div><div class=\"text-size--small text-color--opacity\" style=\"color:var(--color-text-main)\">Increases social interaction and provides joy.<\/div><\/div>\n      <\/div><style data-shopify=\"\">\n          #element-image_NF8kdK {\n            background-color: #ccd6d5; \n          }\n        <\/style>\n<div class=\"item item4 element--no-border text-align--center element--no-radius js-slider-item\">\n\n        <div class=\"card__icon card__icon--is-img card__icon-size--large lazyloaded\" id=\"element-image_aHhVWC\"><img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0801\/1307\/4523\/files\/self-love_1.svg?v=1716999320\" alt=\"\" srcset=\"\n                https:\/\/cdn.shopify.com\/s\/files\/1\/0801\/1307\/4523\/files\/self-love_1.svg?v=1716999320\n                 \n                 \n                 \n              \" loading=\"lazy\" sizes=\"(max-width: 474px) 60px, (max-width: 1023px) 80px, 110px\" width=\"64\" height=\"64\" onload=\"this.parentNode.classList.add('lazyloaded')\"><\/div>\n\n        <div class=\"gutter--regular spacing--small remove-empty-space\"><div style=\"color:var(--color-text-main)\">\n              <h3 class=\"h5\" style=\"margin-bottom:0;display:block\"><span class=\"text-animation--underline\">Promotes Relaxation<\/span><\/h3>\n            <\/div><div class=\"text-size--small text-color--opacity\" style=\"color:var(--color-text-main)\">Stimulate senses in a relaxed, enjoyable way.<\/div><\/div>\n      <\/div><style data-shopify=\"\">\n          #element-image_aHhVWC {\n            background-color:#ffdbd6;\n          }\n        <\/style>\n<div class=\"item item5 element--no-border text-align--center element--no-radius js-slider-item\">\n\n        <div class=\"card__icon card__icon--is-img card__icon-size--large lazyloaded\" id=\"element-image_yHcJcj\"><img src=\