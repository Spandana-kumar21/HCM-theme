      "blocks": {
        "template--20503782687067__6e087eab-3dbe-4205-8598-6edc1efc119b-title-1": {
          "type": "title",
          "settings": {
            "title": "Person-centred",
            "title_size": "h2",
            "seo_h_tag": "h2"
          }
        },
        "text_37F7HA": {
          "type": "text",
          "settings": {
            "text": "<p>Stimulate a more intimate atmosphere, where you can truly connect and build trust with the people you take care of. <\/p>",
            "text_size": "large"
          }
        },
        "text_THFAz9": {
          "type": "text",
          "settings": {
            "text": "<p>Tovertafel Pixie's projector has been designed specifically for sessions between one resident or a small group and a care professional or family member. <\/p>",
            "text_size": "regular"
          }
        }
      },
      "block_order": [
