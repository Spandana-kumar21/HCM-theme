          }
        },
        "text_6Bkaim": {
          "type": "text",
          "settings": {
            "text": "<p>The interactive games and soothing images of the Tovertafel Pixie can be projected on multiple surfaces, automatically adjusting to each situation.<\/p>",
            "text_size": "large"
          }
        },
        "text_B8AjD6": {
          "type": "text",
          "settings": {
            "text": "<p>Effortlessly, create a meaningful recreational activity that stimulates residents, have fun playing a game on the table during a family visit, or generate a peaceful moment before going to sleep with pleasing images on the wall or ceiling.<\/p>",
            "text_size": "regular"
          }
        }
      },
