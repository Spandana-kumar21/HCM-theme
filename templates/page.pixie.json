    "rich_text_wkfpdL": {
      "type": "rich-text",
      "blocks": {
        "title_dY4k3Y": {
          "type": "title",
          "settings": {
            "title": "Mobile",
            "title_size": "h2",
            "seo_h_tag": "h2"
          }
        },
        "text_d4CQAg": {
          "type": "text",
          "settings": {
            "text": "<p>Provide the best care to residents where it is needed! For example, the Tovertafel Pixie can be used in a resident's bedroom to calm them down. <\/p>",
            "text_size": "large"
          }
        },
        "text_Gbzaxh": {
          "type": "text",
          "settings": {
            "text": "<p>Or simply in the living room to play a fun game in a small group. You can easily carry the Tovertafel Pixie to another room, so multiple groups can enjoy and benefit from it!<\/p>",
            "text_size": "regular"
          }
        }
      },
