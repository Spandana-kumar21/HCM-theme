iver or collect rental products to private residences, hotels, or other venues.<\/p>\n\t\n<\/div>","text_size":"regular"}}},"block_order":["text_77abiR"],"custom_css":[".rental-info-block {color: #333;}",".font-weight-bold {font-weight: 700;}",".rental-info-block h5 {font-weight: 700;}",".participating-stores {display: grid; grid-template-columns: 1fr 1fr; margin-bottom: 15px;}",".font-weight-bold-purple {font-weight: 700; color: #350078;}","li::marker {color: #350078;}","@media only screen and (min-width: 768px) {.card__text {padding: 0; }}",".rich-text__container {gap: 40px;}"],"settings":{"image":"shopify:\/\/shop_images\/about-us-homecare-medical_3.png","image_position":"left","height":"small","image_crop":false,"text_alignment":"horizontal-left","is_fullwidth":false,"section_background_color":"rgba(0,0,0,0)","remove_margin":false,"color_background_main":"rgba(0,0,0,0)","color_text_main":"rgba(0,0,0,0)","color_accent_main":"rgba(0,0,0,0)","color_borders_main":"rgba(0,0,0,0)","color_shadow_main":"rgba(0,0,0,0)","color_hide_borders":true,"color_hide_shadow":true}},"165407625224b5d2af":{"type":"rich-text","blocks":{"1654076252f525bcb1-1":{"type":"text","settings":{"text":"<p>RECLINERS<\/p>","text_size":"regular"}},"1654076252f525bcb1-0":{"type":"title","settings":{"title":"Crafted moments of relaxation.","title_size":"h3","seo_h_tag":"h2"}},"4055a9b7-fa9d-4a7a-b5e0-d052561d6f9c":{"type":"text","settings":{"text":"<p>Recline, relax and restore yourself \u2028with our selection of premium recliners.<\/p>","text_size":"regular"}},"1654076252f525bcb1-2":{"type":"button","settings":{"button_label":"View All","link":"shopify:\/\/collections\/recliners","button_size":"large","button_style":"outline"}}},"block_order":["1654076252f525bcb1-1","1654076252f525bcb1-0","4055a9b7-fa9d-4a7a-b5e0-d052561d6f9c","1654076252f525bcb1-2"],"disabled":true,"custom_css":[".rich-text__container {grid-template-columns: 1fr 1.6fr;}",".rich-text__title {font-weight: 400;}",".button--outline:ho