        "title_QKjHVG": {
          "type": "title",
          "settings": {
            "title": "Switching to Solar",
            "title_size": "h3",
            "seo_h_tag": "h2"
          }
        },
        "text_ifqeMp": {
          "type": "text",
          "settings": {
            "text": "<p>In 2023, we implemented solar panels on our distribution centre. In March we installed a 25kw system in our distribution centre in Kiltimagh.<\/p>",
            "text_size": "large"
          }
        },
        "text_zBKQrj": {
          "type": "text",
          "settings": {
            "text": "<p><strong>Result<\/strong> The system has produced 12.477MWh in a six-month period and drastically reduced the buildings energy consumption from the grid.<\/p>",
            "text_size": "regular"
          }
        }
      },
      "block_order": [
