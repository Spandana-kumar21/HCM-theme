        "title_bkjea3": {
          "type": "title",
          "settings": {
            "title": "Maximizing Smart Technology",
            "title_size": "h3",
            "seo_h_tag": "h2"
          }
        },
        "text_4RrXL6": {
          "type": "text",
          "settings": {
            "text": "<p>Logistics Department – In 2019, Homecare Medical introduced smart routes, a route optimisation software.\u2028Result 30% more eco<\/p>",
            "text_size": "large"
          }
        },
        "text_36yn7Q": {
          "type": "text",
          "settings": {
            "text": "<p><strong>Result <\/strong>30% more economical with our route planning<\/p>",
            "text_size": "regular"
          }
        },
        "text_3wXqjA": {
          "type": "text",
          "settings": {
            "text": "<p>Finance Dept – In 2021, We introduced spindle document management system, this allows accounts payable to operate paperless.<\/p>",
            "text_size": "large"
          }
        },
        "text_FA86C8": {
          "type": "text",
          "settings": {
            "text": "<p><strong>Result<\/strong> Reducing paper by 10000 A4 pages a year<\/p>",
            "text_size": "regular"
          }
        }
      },
