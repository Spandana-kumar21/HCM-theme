      "blocks": {
        "text_QURTzt": {
          "type": "text",
          "settings": {
            "text": "<p>We are guided by the United Nations Sustainable Development Goals (UN SDGs), and we’re focused on the four most relevant to our business:<\/p>",
            "text_size": "large"
          }
        },
        "text_wByN7U": {
          "type": "text",
          "settings": {
            "text": "<ul><li>Goal 5: Industry, Innovation and infrastructure\u2028<\/li><li>Goal 6: Sustainable Cities and Community\u2028<\/li><li>Goal 7:: Responsible Consumption & Production<\/li><li>Goal 8: Climate Action<\/li><\/ul>",
            "text_size": "regular"
          }
        }
      },
      "block_order": [
