    "3e119ea9-1b07-4a11-b992-c7f03c9cee14": {
      "type": "rich-text",
      "blocks": {
        "template--20685976404315__3e119ea9-1b07-4a11-b992-c7f03c9cee14-title-1": {
          "type": "title",
          "settings": {
            "title": "Why ISO 14001?",
            "title_size": "h3",
            "seo_h_tag": "h2"
          }
        },
        "template--20685976404315__3e119ea9-1b07-4a11-b992-c7f03c9cee14-text-1": {
          "type": "text",
          "settings": {
            "text": "<p>In 2015, we retained accreditation of ISO 14001 Environmental Management Systems. This accreditation supports us in improving our environmental performance through efficient use of resources and the reduction of waste.<\/p>",
            "text_size": "large"
          }
        },
        "text_HKrRtY": {
          "type": "text",
          "settings": {
            "text": "<ul><li>As part of our effort to maintain this accreditation we conduct audits on waste segregation and employee awareness.<\/li><\/ul>",
            "text_size": "regular"
          }
        }
      },
      "block_order": [
        "template--20685976404315__3e119ea9-1b07-4a11-b992-c7f03c9cee14-title-1",
