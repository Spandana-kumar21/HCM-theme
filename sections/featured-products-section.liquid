{{ 'component-featured-product-item.css' | asset_url | stylesheet_tag }}

<div class="container--large {% unless section.settings.remove_margin %} container--vertical-space {% endunless %} {% if section.settings.section_background_color != "rgba(0,0,0,0)" %} container--has-background {% endif %} remove-empty-space">

  {%- render 'section-heading', heading: section.settings.heading, subheading: section.settings.subheading, button: section.settings.show_view_all, button_label: 'collections.view_all_products', link: collections[section.settings.collection].url, heading_tag: section.settings.seo_h_tag, layout: section.settings.section_heading_layout -%}

  <div>
    <div class="grid grid--layout {{ section.settings.layout }}">
      {%- for block in section.blocks -%}
        {%- assign product = all_products[block.settings.product] -%}
        {%- if product != blank -%}
          <div class="featured-product-item product-card-clickable" 
               data-product-title="{{ product.title }}" 
               data-product-image="{% if product.featured_image != blank %}{{ product.featured_image | image_url: width: 800 }}{% endif %}" 
               {{ block.shopify_attributes }}>
            <div class="featured-product-item__image-wrapper">
              <div class="product-link">
                {%- if product.featured_image != blank -%}
                  {{ product.featured_image | image_url: width: 800 | image_tag: loading: 'lazy', class: 'featured-product-item__image', alt: product.title }}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'featured-product-item__image placeholder-svg' }}
                {%- endif -%}
              </div>
            </div>
            
            <div class="card__text product-item__text gutter--regular spacing--xlarge remove-empty-space text-align--left product-item__content-wrapper">
              <div class="product-item__content-top">
                <div class="product-item__title product-link" title="{{ product.title }}">
                  <div class="remove-line-height-space--small">
                    <span class="text-animation--underline text-size--xlarge text-line-height--small text-weight--bold text-animation--underline">{{ product.title }}</span>
                  </div>
                </div>
                
                {% if block.settings.show_price %}
                <div class="product-item__price text-size--large equalize-white-space">
                  <div class="remove-line-height-space">
                    <div class="product-price">
                      <div class="product-price-original-container_2">
                        <div class="product-price-original-container_inner_2">
                          <span class="product-price--original" data-js-product-price-original="">{{ product.price | money }}</span>
                          <span class="homecare-price-type"></span>
                        </div>
                      </div>
                      <div class="plp-customer-b2b-price"></div>
                      <div class="product-price-original-container_1"></div>
                    </div>
                  </div>
                </div>
                {% endif %}
              </div>
              
              <div class="product-item__quick-buy">
                <quick-add-to-cart class="quick-add-to-cart">
                  <product-form>
                    <div class="quick-add-to-cart-button">
                      <div class="button button--outline button--regular button--fullwidth product-link">
                        <span class="button__text">{{ block.settings.button_text }}</span>
                      </div>
                    </div>
                  </product-form>
                </quick-add-to-cart>
              </div>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}

      {%- if section.blocks.size == 0 -%}
        <div class="placeholder-content">
          <div class="placeholder-content__item">
            {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
            <h3 class="placeholder-content__title">Featured Product</h3>
            <div class="button button--outline button--regular">Shop Now</div>
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>
  
  {%- if section.settings.show_view_all and section.settings.section_heading_layout contains 'center' -%}
    <div class="gutter-top--large align-content align-content--horizontal-center">
      <a class="button button--outline button--regular" href="{{ collections[section.settings.collection].url }}">{{ 'collections.view_all_products' | t }}</a>
    </div>
  {%- endif -%}

</div>

{%- if section.settings.section_background_color != "rgba(0,0,0,0)" -%}
  {% style %}
    #shopify-section-{{ section.id }} .container--has-background {
      --color-background-section: {{ section.settings.section_background_color }};
    }
  {% endstyle %}
{%- endif -%}

{%- if section.settings.section_heading_color != "rgba(0,0,0,0)" -%}
  {% style %}
    #shopify-section-{{ section.id }} {
      --color-text-main: {{ section.settings.section_heading_color }};
    }
  {% endstyle %}
{%- endif -%}

{% style %}
  
  /* Basic styles for the featured product items */
  .featured-product-item {
    margin-bottom: 30px;
    border: solid var(--border-width-cards) var(--color-borders-cards);
    border-radius: var(--border-radius-cards);
    cursor: pointer; /* Add pointer cursor to indicate clickable */
    transition: transform 0.2s ease, box-shadow 0.2s ease; /* Add smooth hover transition */
  }
  
  .featured-product-item:hover {
    transform: translateY(-5px); /* Slight lift effect on hover */
    box-shadow: 0 5px 15px rgba(0,0,0,0.1); /* Add shadow for depth */
  }
  
  .text-animation--underline {
    background-image: linear-gradient(to right, #350078, #350078);
    background-size: 0% 2px;
    background-repeat: no-repeat;
    display: inline !important;
    padding-bottom: 3px;
    transition: all .1s linear;
    color: #350078;
  }
  
  .product-link {
    cursor: pointer;
  }
  
  .featured-product-item__link {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  
  .featured-product-item__image-wrapper {
    margin-bottom: 15px;
    overflow: hidden;
    position: relative;
  }
  
  .quick-add-to-cart-button a, .quick-add-to-cart-button .button {
    color: #350078;
    border: 1px solid #350078;
  }
  
  .quick-add-to-cart-button a:hover, 
  .featured-product-item:hover .quick-add-to-cart-button .button {
    border: 1px solid #350078!important;
    background:#350078!important;
    color:#fff!important;
  }
  
  .featured-product-item__image {
    width: 100%;
    display: block;
    transition: transform 0.5s ease;
  }
  
  .featured-product-item:hover .featured-product-item__image {
    transform: scale(1.05);
  }
  
  .featured-product-item__content {
    padding: 10px 0;
  }
  
  .featured-product-item__title {
    font-size: 18px;
    margin-bottom: 15px;
  }
  
  .featured-product-item__button-wrapper {
    margin-top: 10px;
  }
  
  .featured-product-item__button {
    display: inline-block;
    position: relative;
    z-index: 1;
  }
  
  .featured-product-item__button:hover {
    background-color: var(--color-accent);
    color: #fff;
  }
  
  /* Placeholder content styles */
  .placeholder-content {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
  }
  
  .placeholder-content__item {
    flex: 1;
    min-width: 250px;
    padding: 20px;
    border: 1px dashed #ddd;
    text-align: center;
  }
  
  .placeholder-content__title {
    margin: 15px 0;
    font-size: 18px;
  }
  
  .featured-product-item {
    border: solid var(--border-width-cards) var(--color-borders-cards);
    border-radius: var(--border-radius-cards);
    display: flex;
    flex-direction: column;
  }
  
  .featured-product-item__link {
    display: block;
    text-decoration: none;
    color: var(--color-text-main);
  }
  
  .featured-product-item__image-wrapper {
    position: relative;
    padding-bottom: 100%; /* 1:1 aspect ratio (square) */
    overflow: hidden;
  }
  
  .featured-product-item__image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: contain; /* Changed from cover to contain to maintain image proportions */
    transition: transform 0.5s ease;
  }
  
  .product-item__content-wrapper {
    display: flex;
    flex-direction: column;
    height: 100%;
    justify-content: space-between;
  }
  
  .product-item__content-top {
    flex-grow: 1;
  }
  
  .featured-product-item__content {
    padding: var(--gutter-regular);
  }
  
  .featured-product-item__title {
    margin: 0 0 15px;
    font-size: 18px;
    font-weight: 600;
    line-height: 1.3;
  }
  
  .featured-product-item__button-wrapper {
    margin-top: 15px;
  }
  
  .featured-product-item__button {
    display: inline-block;
    transition: all 0.3s ease;
    position: relative;
    z-index: 1;
    width:100%;
  }
  
  .product-item__content-top{
    margin-bottom: 35px;
  }
  
  /* Responsive adjustments */
  @media screen and (max-width: 768px) {
    .featured-product-item__title {
      font-size: 16px;
    }
    
    .featured-product-item__content {
      padding: 15px;
    }
  }
{% endstyle %}

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Make each product card clickable
  const productCards = document.querySelectorAll('.product-card-clickable');
  
  productCards.forEach(function(card) {
    card.addEventListener('click', function(e) {
      // Check if the click was on an actual link element - if so, let it handle the navigation
      if (e.target.tagName === 'A' || e.target.closest('a')) {
        return; // Let the original link handle it
      }
      
      // Get the product title and image URL from data attributes
      const productTitle = this.getAttribute('data-product-title');
      const productImage = this.getAttribute('data-product-image') || '';
      
      // Redirect to the form page with the product name and image as parameters
      window.location.href = '/pages/seating-and-mobility-range-product-enquiry?product=' + 
                            encodeURIComponent(productTitle) + 
                            '&image=' + encodeURIComponent(productImage);
    });
  });
  
  // Also keep the original button click functionality
  const productLinks = document.querySelectorAll('.product-link');
  
  productLinks.forEach(function(link) {
    link.addEventListener('click', function(e) {
      e.preventDefault();
      e.stopPropagation(); // Prevent the card click from also firing
      
      // Get the product card
      const productCard = this.closest('.product-card-clickable');
      const productTitle = productCard.getAttribute('data-product-title');
      const productImage = productCard.getAttribute('data-product-image') || '';
      
      // Redirect to the form page
      window.location.href = '/pages/seating-and-mobility-range-product-enquiry?product=' + 
                            encodeURIComponent(productTitle) + 
                            '&image=' + encodeURIComponent(productImage);
    });
  });
});
</script>

{% schema %}
  {
    "name": "Featured Products",
    "class": "featured-products-section",
    "blocks": [
      {
        "type": "featured_product",
        "name": "Featured Product",
        "limit": 20,
        "settings": [
          {
            "type": "product",
            "id": "product",
            "label": "Product"
          },
          {
            "type": "checkbox",
            "id": "show_price",
            "label": "Show Price",
            "default": true
          },
          {
            "type": "text",
            "id": "button_text",
            "label": "Button Text",
            "default": "Shop Now"
          }
        ]
      }
    ],
    "settings": [
      {
        "type": "header",
        "content": "Section Heading"
      },
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Featured Products"
      },
      {
        "type": "text",
        "id": "subheading",
        "label": "Subheading",
        "default": "Showcase your best products"
      },
      {
        "type": "checkbox",
        "id": "show_view_all",
        "label": "Show View All button",
        "default": true
      },
      {
        "type": "collection",
        "id": "collection",
        "label": "Collection for View All button"
      },
      {
        "type": "select",
        "id": "section_heading_layout",
        "label": "Text Alignment",
        "options": [
          {
            "value": "section-heading--left",
            "label": "Left"
          },
          {
            "value": "section-heading--center",
            "label": "Center"
          }
        ],
        "default": "section-heading--left"
      },
      {
        "type": "header",
        "content": "Layout"
      },
      {
        "type": "select",
        "id": "layout",
        "label": "Columns",
        "options": [
          {
            "value": "grid-3 grid-lap-2 grid-tiny-1",
            "label": "3 columns"
          },
          {
            "value": "grid-4 grid-portable-3 grid-lap-2 grid-tiny-1",
            "label": "4 columns"
          }
        ],
        "default": "grid-4 grid-portable-3 grid-lap-2 grid-tiny-1"
      },
      {
        "type": "header",
        "content": "Section Design"
      },
      {
        "type": "color",
        "id": "section_background_color",
        "label": "Background Color",
        "default": "rgba(0,0,0,0)"
      },
      {
        "type": "color",
        "id": "section_heading_color",
        "label": "Heading Text Color",
        "default": "rgba(0,0,0,0)"
      },
      {
        "type": "checkbox",
        "id": "remove_margin",
        "label": "Remove section margin",
        "default": false
      },
      {
        "type": "header",
        "content": "SEO"
      },
      {
        "type": "select",
        "id": "seo_h_tag",
        "label": "Heading Tag",
        "info": "Select the appropriate heading tag for SEO purposes",
        "options": [
          {
            "value": "h1",
            "label": "H1"
          },
          {
            "value": "h2",
            "label": "H2"
          },
          {
            "value": "h3",
            "label": "H3"
          },
          {
            "value": "h4",
            "label": "H4"
          },
          {
            "value": "span",
            "label": "span"
          }
        ],
        "default": "h2"
      }
    ],
    "presets": [{
      "name": "Featured Products",
      "blocks": [
        { "type": "featured_product" }
      ]
    }],
    "disabled_on": {
